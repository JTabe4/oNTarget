// ------------------------------------------------------------------
// firestore.rules
// ------------------------------------------------------------------
// Deploy with:  firebase deploy --only firestore:rules
//
// This file covers the collections we use today:
//   users/{uid}
//   usernames/{lowercaseUsername}
//   goals/{goalId}
//
// Rule of thumb: rules don't *filter* — they *validate* every read
// or write.  Queries succeed only if every possible result would
// satisfy the rule.  We design queries (e.g., where('ownerId', '==',
// myUid)) to match the rules below.
// ------------------------------------------------------------------

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------
    // User profile docs
    // --------------------------------------------------------------
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // --------------------------------------------------------------
    // Username uniqueness index — see context/AuthContext.tsx
    // Each doc looks like { uid: "abc123" } and its ID is the
    // lowercase username it claims.
    // --------------------------------------------------------------
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Username re-assignment requires a Cloud Function so it can
      // also rewrite /users/{uid}; block client edits for now.
      allow update, delete: if false;
    }

    // --------------------------------------------------------------
    // Goals — personal (private to owner) or team (visible to all
    // members of the goal's team).
    //
    //   ownerType: 'personal' | 'team' | 'coach_assigned'
    //   teamId:    string | null
    //
    // Source of truth for "can I see this goal":
    //   - I own it (ownerId == auth.uid), OR
    //   - It's a team goal whose teamId I'm a member of.
    //
    // Mutations (edit / archive / delete) stay restricted to the
    // creator for MVP — even for team goals.
    // --------------------------------------------------------------
    match /goals/{goalId} {

      function isMemberOfTeam(teamId) {
        return exists(
          /databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid)
        );
      }

      // Read: I own it OR I'm in the team it belongs to.
      // The client list-query branches into two queries
      // (where ownerId == me, and where teamId in [my teams])
      // and every result of either is independently allowed below.
      allow read: if request.auth != null
                  && (
                    resource.data.ownerId == request.auth.uid
                    ||
                    (resource.data.teamId is string && isMemberOfTeam(resource.data.teamId))
                  );

      // Create: must mark *yourself* as owner, AND:
      //   - personal goal → teamId must be null
      //   - team goal     → teamId must be a team you belong to
      //   - coach_assigned goals can't be self-created here yet
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && (
                      (
                        request.resource.data.ownerType == 'personal'
                        && request.resource.data.teamId == null
                      )
                      ||
                      (
                        request.resource.data.ownerType == 'team'
                        && request.resource.data.teamId is string
                        && isMemberOfTeam(request.resource.data.teamId)
                      )
                    );

      // Update: only the creator.  ownerId and teamId are immutable
      // (no transferring goals between owners or moving them between
      // teams from the client).
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.teamId == resource.data.teamId;

      // Delete: only the creator.  The MVP archives via update; this
      // door is open for account-deletion / cleanup flows.
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // --------------------------------------------------------------
    // Goal updates — text/image posts attached to a goal.
    //
    // Read parity with the parent goal: if you can see the goal,
    // you can see its updates.  Posting an update is still owner-
    // only for MVP (we haven't shipped team-side posting yet).
    // --------------------------------------------------------------
    match /goalUpdates/{updateId} {

      // Read parent-goal data once.  Used by both read and create
      // rules below — get() counts as one read per rule evaluation.
      function goalData(goalId) {
        return get(/databases/$(database)/documents/goals/$(goalId)).data;
      }
      function canSeeGoal(goalId) {
        let g = goalData(goalId);
        return g.ownerId == request.auth.uid
               || (
                 g.teamId is string
                 && exists(
                   /databases/$(database)/documents/teamMembers/$(g.teamId + '_' + request.auth.uid)
                 )
               );
      }

      // Read: anyone who can see the underlying goal.
      allow read: if request.auth != null
                  && canSeeGoal(resource.data.goalId);

      // Create: still restricted to the goal owner for MVP.  Adding
      // team-member posting would just relax this branch.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && goalData(request.resource.data.goalId).ownerId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0;

      // Updates are immutable in MVP.  Edits/deletes will need a
      // separate flow (and rules) — block them for now.
      allow update, delete: if false;
    }

    // --------------------------------------------------------------
    // Teams — read by members; write by the team leader.
    //
    // Membership is the source of truth for "can I read this team",
    // looked up by the deterministic membership id `teamId_userId`.
    // --------------------------------------------------------------
    match /teams/{teamId} {

      function isMember() {
        return exists(
          /databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid)
        );
      }

      // Read: members only.
      allow read: if request.auth != null && isMember();

      // Create: must declare yourself as the team leader, with your
      // own username denormalized onto the doc.
      allow create: if request.auth != null
                    && request.resource.data.teamLeaderId == request.auth.uid
                    && request.resource.data.teamLeaderUsername is string;

      // Update: only the (current) team leader; teamLeaderId cannot
      // change (no transferring leadership client-side yet).
      allow update: if request.auth != null
                    && resource.data.teamLeaderId == request.auth.uid
                    && request.resource.data.teamLeaderId == resource.data.teamLeaderId;

      allow delete: if false;
    }

    // --------------------------------------------------------------
    // Invite-code lookup table.
    //
    // Doc id == invite code.  Doc body == { teamId: ... }.
    // Anyone signed in may read so that a not-yet-member can resolve
    // a code → teamId before joining.
    // --------------------------------------------------------------
    match /inviteCodes/{code} {
      allow read: if request.auth != null;

      // Created during the team-create flow.  We don't have a robust
      // way to gate this further without a Cloud Function — anyone
      // signed in can claim an unused code.  This is acceptable for
      // MVP because the doc only stores a teamId pointer, not real
      // privileges.
      allow create: if request.auth != null
                    && request.resource.data.teamId is string;

      allow update, delete: if false;
    }

    // --------------------------------------------------------------
    // Team memberships.
    //
    // Doc id MUST equal `${teamId}_${userId}` — this is how we
    // structurally prevent duplicate memberships.
    // --------------------------------------------------------------
    match /teamMembers/{membershipId} {

      // Read: a user can read all members of any team they belong to.
      allow read: if request.auth != null
                  && exists(
                    /databases/$(database)/documents/teamMembers/$(resource.data.teamId + '_' + request.auth.uid)
                  );

      // Create: tightly constrained.
      //   - You can only create your own membership.
      //   - The doc id must match the deterministic pattern.
      //   - If you're claiming the `team_leader` role we accept it
      //     unconditionally — the team's own rules check
      //     `team.teamLeaderId` for any leader-only operation, so a
      //     fake leader-membership grants no privileged access.
      //     (The UI uses team.teamLeaderId as source of truth.)
      //   - If you're joining as a `member`, the request must include
      //     an inviteCode that points to the same teamId in the
      //     /inviteCodes lookup table.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && membershipId == request.resource.data.teamId + '_' + request.resource.data.userId
                    && (
                      request.resource.data.role == 'team_leader'
                      ||
                      (
                        request.resource.data.role == 'member'
                        && exists(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode))
                        && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode)).data.teamId == request.resource.data.teamId
                      )
                    );

      // No role changes from the client yet.
      allow update: if false;

      // A user may delete their own membership (= leave team).  Not
      // wired into the MVP UI but the rule is here so we don't have
      // to amend it later.
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}
