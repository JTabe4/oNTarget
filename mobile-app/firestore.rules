// ------------------------------------------------------------------
// firestore.rules
// ------------------------------------------------------------------
// Deploy with:  firebase deploy --only firestore:rules
//
// This file covers the collections we use today:
//   users/{uid}
//   usernames/{lowercaseUsername}
//   goals/{goalId}
//
// Rule of thumb: rules don't *filter* — they *validate* every read
// or write.  Queries succeed only if every possible result would
// satisfy the rule.  We design queries (e.g., where('ownerId', '==',
// myUid)) to match the rules below.
// ------------------------------------------------------------------

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------
    // User profile docs
    // --------------------------------------------------------------
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // --------------------------------------------------------------
    // Username uniqueness index — see context/AuthContext.tsx
    // Each doc looks like { uid: "abc123" } and its ID is the
    // lowercase username it claims.
    // --------------------------------------------------------------
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Username re-assignment requires a Cloud Function so it can
      // also rewrite /users/{uid}; block client edits for now.
      allow update, delete: if false;
    }

    // --------------------------------------------------------------
    // Goals — only the owner can read or write their goals, and the
    // owner can never be changed.
    // --------------------------------------------------------------
    match /goals/{goalId} {
      // Read access: must be signed in AND the goal must belong to you.
      // Combined with the client query `where('ownerId', '==', myUid)`,
      // this allows list operations.
      allow read: if request.auth != null
                  && resource.data.ownerId == request.auth.uid;

      // Create: the new doc must mark *you* as the owner.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Update: you must already be the owner AND ownerId must not
      // change.  This prevents another user from "stealing" a goal,
      // and prevents accidental ownership changes from the client.
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId;

      // Delete: only the owner.  (The MVP archives instead, but this
      // rule keeps the door open for account-deletion flows.)
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // --------------------------------------------------------------
    // Goal updates — text/image posts attached to a goal.
    //
    // MVP rule of thumb: only the goal's owner can read or post
    // updates for it.  Later, when group/coach visibility lands, the
    // read rule will branch on goal.visibility and group membership.
    // --------------------------------------------------------------
    match /goalUpdates/{updateId} {

      // Look up the related goal once per evaluation to check
      // ownership.  `get()` counts as one read against the request.
      function goalOwnerId(goalId) {
        return get(/databases/$(database)/documents/goals/$(goalId)).data.ownerId;
      }

      // Read: signed-in users may read an update if they own the
      // related goal.  (Same constraint as the goal itself for MVP.)
      allow read: if request.auth != null
                  && goalOwnerId(resource.data.goalId) == request.auth.uid;

      // Create: the doc's userId must be the signed-in user, AND
      // they must own the goal they're posting to.  The text field
      // must be non-empty.  imageUrl may be null or a string.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && goalOwnerId(request.resource.data.goalId) == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0;

      // Updates are immutable in MVP.  Edits/deletes will need a
      // separate flow (and rules) — block them for now.
      allow update, delete: if false;
    }

    // --------------------------------------------------------------
    // Teams — read by members; write by the team leader.
    //
    // Membership is the source of truth for "can I read this team",
    // looked up by the deterministic membership id `teamId_userId`.
    // --------------------------------------------------------------
    match /teams/{teamId} {

      function isMember() {
        return exists(
          /databases/$(database)/documents/teamMembers/$(teamId + '_' + request.auth.uid)
        );
      }

      // Read: members only.
      allow read: if request.auth != null && isMember();

      // Create: must declare yourself as the team leader, with your
      // own username denormalized onto the doc.
      allow create: if request.auth != null
                    && request.resource.data.teamLeaderId == request.auth.uid
                    && request.resource.data.teamLeaderUsername is string;

      // Update: only the (current) team leader; teamLeaderId cannot
      // change (no transferring leadership client-side yet).
      allow update: if request.auth != null
                    && resource.data.teamLeaderId == request.auth.uid
                    && request.resource.data.teamLeaderId == resource.data.teamLeaderId;

      allow delete: if false;
    }

    // --------------------------------------------------------------
    // Invite-code lookup table.
    //
    // Doc id == invite code.  Doc body == { teamId: ... }.
    // Anyone signed in may read so that a not-yet-member can resolve
    // a code → teamId before joining.
    // --------------------------------------------------------------
    match /inviteCodes/{code} {
      allow read: if request.auth != null;

      // Created during the team-create flow.  We don't have a robust
      // way to gate this further without a Cloud Function — anyone
      // signed in can claim an unused code.  This is acceptable for
      // MVP because the doc only stores a teamId pointer, not real
      // privileges.
      allow create: if request.auth != null
                    && request.resource.data.teamId is string;

      allow update, delete: if false;
    }

    // --------------------------------------------------------------
    // Team memberships.
    //
    // Doc id MUST equal `${teamId}_${userId}` — this is how we
    // structurally prevent duplicate memberships.
    // --------------------------------------------------------------
    match /teamMembers/{membershipId} {

      // Read: a user can read all members of any team they belong to.
      allow read: if request.auth != null
                  && exists(
                    /databases/$(database)/documents/teamMembers/$(resource.data.teamId + '_' + request.auth.uid)
                  );

      // Create: tightly constrained.
      //   - You can only create your own membership.
      //   - The doc id must match the deterministic pattern.
      //   - If you're claiming the `team_leader` role we accept it
      //     unconditionally — the team's own rules check
      //     `team.teamLeaderId` for any leader-only operation, so a
      //     fake leader-membership grants no privileged access.
      //     (The UI uses team.teamLeaderId as source of truth.)
      //   - If you're joining as a `member`, the request must include
      //     an inviteCode that points to the same teamId in the
      //     /inviteCodes lookup table.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && membershipId == request.resource.data.teamId + '_' + request.resource.data.userId
                    && (
                      request.resource.data.role == 'team_leader'
                      ||
                      (
                        request.resource.data.role == 'member'
                        && exists(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode))
                        && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode)).data.teamId == request.resource.data.teamId
                      )
                    );

      // No role changes from the client yet.
      allow update: if false;

      // A user may delete their own membership (= leave team).  Not
      // wired into the MVP UI but the rule is here so we don't have
      // to amend it later.
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}
